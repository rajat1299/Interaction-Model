# Required for OpenAI API requests.
OPENAI_API_KEY=

# Optional account routing. Leave blank unless the project needs explicit routing.
OPENAI_PROJECT_ID=
OPENAI_ORG_ID=

# Prompted teacher defaults selected by the WP13 calibration pilot.
IM_TEACHER_MODEL=gpt-5.6-terra
IM_TEACHER_REASONING_EFFORT=high
IM_TEACHER_MAX_OUTPUT_TOKENS=8192
